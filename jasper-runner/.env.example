# DB Production (db)
DB_HOST=
DB_PORT=
DB_DATABASE=
DB_USER=
DB_PASSWORD=

# Mailer Production (mailer)
MAILER_HOST=smtp.hostinger.com
MAILER_PORT=465
MAILER_SECURE=true
MAILER_USER=
MAILER_PASS=

# Declarar o tipo de banco de dados. Se não declarar então a api entenderá como mysql
SPRING_JPA_DATABASE_PLATFORM=org.hibernate.dialect.MariaDBDialect

# URL pública da aplicação (links nos e-mails). Se omitir, usa o domínio da requisição HTTP.
APP_BASE_URL=https://reports.seudominio.com