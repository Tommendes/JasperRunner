{
  "info": {
    "name": "JasperRunner API Collection",
    "description": "Collection Postman v2.1 para JasperRunner. API REST usa HTTP Basic (apiUser/apiPass). Login de tela usa sessão (pasta Auth Sessao).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8090" },
    { "key": "apiUser", "value": "admin" },
    { "key": "apiPass", "value": "changeme" },
    { "key": "username", "value": "admin" },
    { "key": "password", "value": "changeme" },
    { "key": "csrfToken", "value": "" },
    { "key": "reportId", "value": "1" },
    { "key": "datasourceId", "value": "1" },
    { "key": "folderId", "value": "1" }
  ],
  "item": [
    {
      "name": "Auth (Sessao Web)",
      "item": [
        {
          "name": "GET /login (captura CSRF)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const html = pm.response.text();",
                  "const m = html.match(/name=\\\"_csrf\\\"\\s+value=\\\"([^\\\"]+)\\\"/);",
                  "pm.test('CSRF encontrado', function () { pm.expect(m).to.not.equal(null); });",
                  "if (m && m[1]) pm.collectionVariables.set('csrfToken', m[1]);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/login"
          }
        },
        {
          "name": "POST /login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/x-www-form-urlencoded" }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "username", "value": "{{username}}", "type": "text" },
                { "key": "password", "value": "{{password}}", "type": "text" },
                { "key": "_csrf", "value": "{{csrfToken}}", "type": "text" }
              ]
            },
            "url": "{{baseUrl}}/login"
          }
        }
      ]
    },
    {
      "name": "Reports (API Basic)",
      "item": [
        {
          "name": "GET /api/reports (sem auth — deve falhar)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": "{{baseUrl}}/api/reports"
          }
        },
        {
          "name": "GET /api/reports",
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                { "key": "username", "value": "{{apiUser}}", "type": "string" },
                { "key": "password", "value": "{{apiPass}}", "type": "string" }
              ]
            },
            "method": "GET",
            "url": "{{baseUrl}}/api/reports"
          }
        },
        {
          "name": "GET /api/reports/{id}",
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                { "key": "username", "value": "{{apiUser}}", "type": "string" },
                { "key": "password", "value": "{{apiPass}}", "type": "string" }
              ]
            },
            "method": "GET",
            "url": "{{baseUrl}}/api/reports/{{reportId}}"
          }
        },
        {
          "name": "POST /api/reports (multipart upload)",
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                { "key": "username", "value": "{{apiUser}}", "type": "string" },
                { "key": "password", "value": "{{apiPass}}", "type": "string" }
              ]
            },
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": "" },
                { "key": "name", "value": "meuRelatorio", "type": "text" },
                { "key": "description", "value": "Upload via Postman", "type": "text" },
                { "key": "folderId", "value": "{{folderId}}", "type": "text" }
              ]
            },
            "url": "{{baseUrl}}/api/reports"
          }
        },
        {
          "name": "POST /api/reports/{id}/run",
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                { "key": "username", "value": "{{apiUser}}", "type": "string" },
                { "key": "password", "value": "{{apiPass}}", "type": "string" }
              ]
            },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"parameters\": {\n    \"param1\": \"valor\",\n    \"param2\": \"valor\"\n  },\n  \"datasourceId\": {{datasourceId}},\n  \"format\": \"PDF\"\n}"
            },
            "url": "{{baseUrl}}/api/reports/{{reportId}}/run"
          }
        },
        {
          "name": "DELETE /api/reports/{id}",
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                { "key": "username", "value": "{{apiUser}}", "type": "string" },
                { "key": "password", "value": "{{apiPass}}", "type": "string" }
              ]
            },
            "method": "DELETE",
            "url": "{{baseUrl}}/api/reports/{{reportId}}"
          }
        }
      ]
    },
    {
      "name": "Datasources (API Basic)",
      "item": [
        {
          "name": "GET /api/datasources",
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                { "key": "username", "value": "{{apiUser}}", "type": "string" },
                { "key": "password", "value": "{{apiPass}}", "type": "string" }
              ]
            },
            "method": "GET",
            "url": "{{baseUrl}}/api/datasources"
          }
        },
        {
          "name": "POST /api/datasources",
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                { "key": "username", "value": "{{apiUser}}", "type": "string" },
                { "key": "password", "value": "{{apiPass}}", "type": "string" }
              ]
            },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Mega\",\n  \"description\": \"Conexao MySQL\",\n  \"driverClassName\": \"com.mysql.cj.jdbc.Driver\",\n  \"url\": \"jdbc:mysql://localhost:3306/seu_banco?useSSL=false&serverTimezone=UTC\",\n  \"username\": \"root\",\n  \"encryptedPassword\": \"sua_senha_aqui\"\n}"
            },
            "url": "{{baseUrl}}/api/datasources"
          }
        },
        {
          "name": "PUT /api/datasources/{id}",
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                { "key": "username", "value": "{{apiUser}}", "type": "string" },
                { "key": "password", "value": "{{apiPass}}", "type": "string" }
              ]
            },
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Mega\",\n  \"description\": \"Conexao MySQL atualizada\",\n  \"driverClassName\": \"com.mysql.cj.jdbc.Driver\",\n  \"url\": \"jdbc:mysql://localhost:3306/seu_banco?useSSL=false&serverTimezone=UTC\",\n  \"username\": \"root\",\n  \"encryptedPassword\": \"nova_senha\"\n}"
            },
            "url": "{{baseUrl}}/api/datasources/{{datasourceId}}"
          }
        },
        {
          "name": "POST /api/datasources/{id}/test",
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                { "key": "username", "value": "{{apiUser}}", "type": "string" },
                { "key": "password", "value": "{{apiPass}}", "type": "string" }
              ]
            },
            "method": "POST",
            "url": "{{baseUrl}}/api/datasources/{{datasourceId}}/test"
          }
        },
        {
          "name": "DELETE /api/datasources/{id}",
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                { "key": "username", "value": "{{apiUser}}", "type": "string" },
                { "key": "password", "value": "{{apiPass}}", "type": "string" }
              ]
            },
            "method": "DELETE",
            "url": "{{baseUrl}}/api/datasources/{{datasourceId}}"
          }
        }
      ]
    }
  ]
}
